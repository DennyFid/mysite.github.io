<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Posts - Tripperist</title>
<style>
:root {
--bg: #1a1a2e;
--bg-secondary: #16213e;
--text: #e0e0e0;
--text-secondary: #b0b0b0;
--text-tertiary: #7c9fd8;
--border: #2a2a3e;
--primary: #667eea;
}

html.light-mode {
--bg: #f5f5f5;
--bg-secondary: #ffffff;
--text: #333;
--text-secondary: #555;
--text-tertiary: #667eea;
--border: #e5e5e5;
}

* {
margin: 0;
padding: 0;
box-sizing: border-box;
}

body {
font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Roboto', 'Oxygen', 'Ubuntu', 'Cantarell', 'Fira Sans', 'Droid Sans', 'Helvetica Neue', sans-serif;
background: var(--bg);
color: var(--text);
line-height: 1.6;
transition: background-color 0.3s, color 0.3s;
}

header {
background: var(--bg-secondary);
border-bottom: 1px solid var(--border);
padding: 20px 0;
position: sticky;
top: 0;
z-index: 100;
}

.header-container {
max-width: 1000px;
margin: 0 auto;
padding: 0 20px;
display: flex;
justify-content: space-between;
align-items: center;
}

.logo {
font-size: 1.5em;
font-weight: bold;
color: var(--primary);
text-decoration: none;
}

nav {
display: flex;
align-items: center;
gap: 20px;
}

nav a {
text-decoration: none;
color: var(--text);
font-weight: 500;
transition: color 0.3s;
}

nav a:hover {
color: var(--primary);
}

.theme-toggle {
display: flex;
align-items: center;
gap: 10px;
cursor: pointer;
}

.toggle-switch {
width: 50px;
height: 28px;
background: var(--border);
border-radius: 14px;
position: relative;
display: flex;
align-items: center;
padding: 0 2px;
transition: background-color 0.3s;
border: 1px solid var(--border);
}

.toggle-switch.active {
background: var(--primary);
border-color: var(--primary);
}

.toggle-circle {
width: 24px;
height: 24px;
background: white;
border-radius: 50%;
position: absolute;
left: 2px;
transition: left 0.3s;
display: flex;
align-items: center;
justify-content: center;
font-size: 14px;
}

.toggle-switch.active .toggle-circle {
left: 24px;
}

.toggle-label {
font-size: 0.9em;
color: var(--text-secondary);
white-space: nowrap;
}

.main-container {
display: grid;
grid-template-columns: 1fr 3fr;
max-width: 1200px;
margin: 40px auto;
padding: 0 20px;
gap: 40px;
}

.sidebar {
background: var(--bg-secondary);
border-radius: 8px;
padding: 30px;
border: 1px solid var(--border);
height: fit-content;
position: sticky;
top: 100px;
}

.sidebar-avatar {
width: 100px;
height: 100px;
border-radius: 50%;
background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
margin: 0 auto 20px;
display: flex;
align-items: center;
justify-content: center;
font-size: 2em;
}

.sidebar-name {
text-align: center;
color: var(--text);
font-size: 1.3em;
font-weight: bold;
margin-bottom: 10px;
}

.sidebar-bio {
text-align: center;
color: var(--text-secondary);
font-size: 0.95em;
margin-bottom: 25px;
line-height: 1.6;
}

.sidebar-follow {
text-align: center;
padding: 15px;
background: rgba(102, 126, 234, 0.1);
border-radius: 5px;
margin-bottom: 20px;
}

.follow-btn {
background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
color: white;
border: none;
padding: 10px 20px;
border-radius: 4px;
cursor: pointer;
font-weight: bold;
transition: transform 0.3s;
}

.follow-btn:hover {
transform: translateY(-2px);
}

.sidebar-social {
display: flex;
justify-content: center;
gap: 15px;
flex-wrap: wrap;
}

.sidebar-social a {
text-decoration: none;
color: var(--text-tertiary);
font-size: 0.9em;
transition: color 0.3s;
}

.sidebar-social a:hover {
color: #a8c5e0;
}

.content {
background: var(--bg-secondary);
border-radius: 8px;
padding: 40px;
border: 1px solid var(--border);
}

.content h1 {
color: var(--text);
font-size: 2.2em;
margin-bottom: 30px;
border-bottom: 2px solid var(--primary);
padding-bottom: 20px;
}

.posts-by-year {
color: var(--text-secondary);
font-size: 0.95em;
margin-bottom: 30px;
}

.year-section {
margin-bottom: 40px;
}

.year-title {
color: var(--primary);
font-size: 1.5em;
margin: 40px 0 25px 0;
font-weight: bold;
}

.post-item {
background: rgba(102, 126, 234, 0.05);
padding: 25px;
margin-bottom: 20px;
border-radius: 6px;
border-left: 4px solid var(--primary);
transition: transform 0.3s, box-shadow 0.3s;
}

html.light-mode .post-item {
background: #f0f7ff;
}

.post-item:hover {
transform: translateX(5px);
box-shadow: 0 4px 12px rgba(102, 126, 234, 0.2);
}

.post-title {
font-size: 1.3em;
color: var(--text);
margin-bottom: 10px;
}

.post-title a {
text-decoration: none;
color: var(--text-tertiary);
transition: color 0.3s;
}

.post-title a:hover {
color: #a8c5e0;
}

.post-meta {
display: flex;
gap: 20px;
margin-bottom: 12px;
color: var(--text-secondary);
font-size: 0.9em;
}

.post-excerpt {
color: var(--text-secondary);
line-height: 1.7;
}

.back-to-top {
text-align: right;
margin-top: 40px;
padding-top: 20px;
border-top: 1px solid var(--border);
}

.back-to-top a {
text-decoration: none;
color: var(--text-tertiary);
transition: color 0.3s;
}

.back-to-top a:hover {
color: #a8c5e0;
}

footer {
background: #0f0f1e;
border-top: 1px solid var(--border);
color: #808080;
text-align: center;
padding: 40px 20px;
margin-top: 60px;
}

html.light-mode footer {
background: #f0f0f0;
color: #666;
}

footer a {
color: var(--text-tertiary);
text-decoration: none;
}

footer a:hover {
text-decoration: underline;
}

.social-links {
display: flex;
gap: 20px;
margin: 20px 0;
flex-wrap: wrap;
justify-content: center;
}

.social-links a {
text-decoration: none;
color: var(--text-tertiary);
font-weight: 500;
transition: color 0.3s;
}

.social-links a:hover {
color: #a8c5e0;
}

@media (max-width: 768px) {
.main-container {
grid-template-columns: 1fr;
}

.sidebar {
position: static;
}

.content {
padding: 20px;
}
}
</style>
</head>
